/* === Global === */

QWidget {
    color: ${text};
    font-family: "Segoe UI", "SF Pro Display", -apple-system, sans-serif;
    font-size: 10pt;
}

/* === Main Window (buitenrand met radius) === */

#mainWindow {
    background-color: ${surface};        /* kies een passende kleur */
    border: 1px solid ${border};
    border-radius: 8px;
}

/* === Menu & Navigation === */

QMenuBar {
    background: ${surface_alt};
    border-bottom: 1px solid ${border};
}

QMenuBar::item {
    padding: 4px 10px;
    margin: 0;
    border-radius: 4px;
}

QMenuBar::item:selected {
    color: ${accent_text};
    background: ${accent};
}

QMenu {
    background: ${surface_floating};
    border: 1px solid ${border};
    border-radius: 6px;
    padding: 6px;
}

QMenu::item {
    padding: 6px 16px;
    border-radius: 4px;
    margin: 1px 4px;
}

QMenu::item:selected {
    color: ${accent_text};
    background: ${accent};
}

/* === Tabs === */

QTabWidget::pane {
    border: 1px solid ${border};
    background: ${surface};
    border-radius: 0 0 8px 8px;
    top: -1px;
}

QTabBar {
    margin-left: 0;
}

QTabBar::tab {
    padding: 10px 20px;
    background: ${surface_raised};
    border: 1px solid ${border};
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 0px;
    color: ${text_secondary};
}

QTabBar::tab:selected {
    background: ${surface};
    color: ${text};
    border-bottom: 1px solid ${surface};
}

QTabBar::tab:!selected {
    margin-top: 2px;
}

/* Compact button variant */
QPushButton[compact="true"] {
    padding: 6px 16px;
    border-radius: 6px;
    font-size: ${font_small}pt;
}

#reloadBtn {
    margin: 2px 4px;
}

/* === Checkboxes === */

QCheckBox {
    spacing: 6px;
    background: transparent;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid ${border_strong};
    border-radius: 4px;
    background: ${surface};
}

QCheckBox::indicator:hover {
    border-color: ${accent};
}

QCheckBox::indicator:checked {
    background: ${accent};
    border-color: ${accent};
    image: url(${images_dir}/check.svg);
}

/* === Buttons === */

QPushButton {
    padding: 10px 20px;
    border: none;
    border-radius: 6px;
    background: ${surface_raised};
    color: ${text};
    font-weight: 500;
}

QPushButton:hover {
    background: ${surface_floating};
}

QPushButton:pressed {
    background: ${surface};
}

/* Primary/Accent button */
QPushButton[primary="true"] {
    background: ${accent};
    color: ${accent_text};
}

QPushButton[primary="true"]:hover {
    background: ${accent_hover};
}

QPushButton[primary="true"]:pressed {
    background: ${accent_pressed};
}

/* === Inputs === */

QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    padding: 10px 12px;
    background: ${surface_raised};
    border: 1px solid ${border};
    border-radius: 6px;
    color: ${text};
    selection-background-color: ${accent};
}

QLineEdit:focus, QComboBox:focus, QSpinBox:focus {
    border-color: ${accent};
    border-width: 2px;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background: ${surface_floating};
    border: 1px solid ${border};
    border-radius: 6px;
    padding: 6px;
    selection-background-color: ${accent};
}

/* === Scrollbars === */

QScrollBar:vertical {
    background: transparent;
    width: 12px;
    margin: 4px;
}

QScrollBar::handle:vertical {
    background: ${border};
    border-radius: 6px;
    min-height: 40px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: ${text_muted};
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

/* === Tables === */

QTableView, QTableWidget {
    background: ${surface};
    alternate-background-color: ${surface_alt};
    gridline-color: ${border};
    border: none;
    selection-background-color: ${accent}80;
    selection-color: ${text};
    border-radius: 8px;
}

QHeaderView::section {
    background: ${surface_raised};
    color: ${text_secondary};
    border: none;
    border-bottom: 2px solid ${border};
    padding: 12px 16px;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85em;
    letter-spacing: 0.5px;
}

QTableView::item {
    padding: 12px;
    border-bottom: 1px solid ${border};
}

QTableView::item:selected {
    background: ${accent}40;
    color: ${text};
}

/* === Cards/Groups === */

QGroupBox {
    background: ${surface_raised};
    border: 1px solid ${border};
    border-radius: 12px;
    margin-top: 16px;
    padding: 20px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 16px;
    padding: 0 8px;
    color: ${text_secondary};
}

/* === Title Bar === */

#titleBar {
    background: ${surface_raised};
    border-bottom: 1px solid ${border};
}

#titleBarLabel {
    color: ${text};
    font-weight: 600;
    font-size: ${font_small}pt;
    background: transparent;
}

#titleBarBtn {
    background: transparent;
    border: none;
    border-radius: 4px;
    color: ${text_secondary};
    font-size: 12px;
}

#titleBarBtn:hover {
    background: ${surface_floating};
    color: ${text};
}

#titleBarCloseBtn {
    background: transparent;
    border: none;
    border-radius: 4px;
    color: ${text_secondary};
    font-size: 12px;
}

#titleBarCloseBtn:hover {
    background: ${danger};
    color: ${accent_text};
}

/* === Dialogs / Message Boxes === */

QMessageBox, QDialog {
    background: ${surface_alt};
    color: ${text};
}

QMessageBox QLabel {
    color: ${text};
}

QMessageBox QPushButton {
    min-width: 80px;
}

/* === Tooltips === */

QToolTip {
    color: ${text};
    background: ${surface_floating};
    border: 1px solid ${border};
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 0.9em;
}

/* === Widget List (Custom) === */

#widgetList, #widgetListContainer {
    background: ${surface};
    border: none;
    border-radius: 0;
}

#widgetRow {
    background: ${surface};
    border-bottom: 1px solid ${border};
    padding: 4px;
    min-height: 32px;
}

#widgetRow[alt=true] {
    background: ${surface_alt};
}

#widgetRow:hover {
    background: ${surface_raised};
}

#widgetTitle {
    font-weight: 600;
    font-size: ${font_title}pt;
    color: ${text};
    background: transparent;
}

#widgetDesc {
    color: ${text_secondary};
    font-size: ${font_small}pt;
    background: transparent;
    margin-top: 4px;
}

#widgetConfigBtn {
    font-size: ${font_button}pt;
    padding: 8px 16px;
    border-radius: 6px;
    background: ${accent};
    color: ${accent_text};
    border: none;
}

#widgetConfigBtn:hover {
    background: ${accent_hover};
}
