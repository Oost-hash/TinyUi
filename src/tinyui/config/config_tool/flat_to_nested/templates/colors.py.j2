# Auto-generated color palettes

from dataclasses import dataclass


@dataclass(frozen=True)
class Palette:
    font: str
    bkg: str

{% for palette in palettes %}
{{ palette.name }} = Palette("{{ palette.font_color }}", "{{ palette.bkg_color }}")
{%- endfor %}

ALL = [
{%- for palette in palettes %}
    {{ palette.name }},
{%- endfor %}
]
