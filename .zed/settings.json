{
  "file_scan_exclusions": [],
  "languages": {
    "Python": {
      "language_servers": ["basedpyright"],
    },
    "QML": {
      "language_servers": ["qmljs"],
    },
  },
  "lsp": {
    "basedpyright": {
      "binary": {
        "path": ".venv/Scripts/basedpyright-langserver.exe",
        "//": "Use the project's venv-based basedpyright so Zed follows pyproject.toml strict mode.",
        "arguments": ["--stdio"],
      },
    },
    "qmljs": {
      "binary": {
        "path": ".venv/Lib/site-packages/PySide6/qmlls.exe",
        "//": "Use PySide6 from the project venv so Zed follows scripts/qmllint.py and does not rely on generated .qml_linter metadata.",
        "arguments": ["--no-cmake-calls"],
      },
    },
  },
}
